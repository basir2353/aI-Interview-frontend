# Backend origin (no trailing slash). Used by /api/proxy and server-side API calls.
# Local: http://localhost:4000
# Production (Vercel): https://your-backend.onrender.com
BACKEND_URL=http://localhost:4000

# Public env (exposed to browser). Set to your Render backend URL in production.
# Required for Socket.io and voice interview to connect to the backend.
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
