# Frontend app URL (this deployment)
# Production: https://a-i-interview-frontend.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend origin (no trailing slash). Used by /api/proxy and server-side API calls.
# Local development:
BACKEND_URL=http://localhost:4000

# Mic STT: browser calls Railway /api/v1/transcribe directly in production (see src/lib/voiceConnection.ts).
# TTS: always via same-origin /api/proxy/ai/tts
# NEXT_PUBLIC_APP_URL=https://a-i-interview-frontend.vercel.app
# BACKEND_URL=https://ai-interview-backend-production-e046.up.railway.app
# NEXT_PUBLIC_WS_URL=https://ai-interview-backend-production-e046.up.railway.app
# NEXT_PUBLIC_API_URL=https://ai-interview-backend-production-e046.up.railway.app

NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
